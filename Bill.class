<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

<meta charset="UTF-8">

<title>Add Medicine | PharmaLens</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

body{
background:linear-gradient(135deg,#dbeafe,#eef6ff);
font-family:'Segoe UI',sans-serif;
}

.card{
border:none;
border-radius:20px;
overflow:hidden;
box-shadow:0 10px 30px rgba(0,0,0,.2);
}

.card-header{
background:linear-gradient(45deg,#0d6efd,#00b4ff);
color:white;
padding:20px;
}

.card-header h2{
margin:0;
font-weight:bold;
}

.form-control{
border-radius:10px;
height:48px;
}

textarea.form-control{
height:120px;
resize:none;
}

.form-label{
font-weight:600;
}

.btn-success{
background:#198754;
border:none;
padding:12px 30px;
font-size:18px;
border-radius:10px;
}

.btn-success:hover{
background:#157347;
}

.btn-secondary{
padding:12px 30px;
font-size:18px;
border-radius:10px;
}

.icon{
color:#0d6efd;
margin-right:8px;
}

</style>

</head>

<body>

<div class="container py-5">

<div class="row justify-content-center">

<div class="col-lg-10">

<div class="card">

<div class="card-header">

<h2>
<i class="fa-solid fa-capsules"></i>
Add New Medicine
</h2>

</div>

<div class="card-body p-4">

<form th:action="@{/medicine/save}" th:object="${medicine}" method="post">

<div class="row">

<div class="col-md-6 mb-3">

<label class="form-label">
<i class="fa-solid fa-capsules icon"></i>
Medicine Name
</label>

<input
type="text"
class="form-control"
th:field="*{medicineName}"
placeholder="Enter Medicine Name"
required>

</div>

<div class="col-md-6 mb-3">

<label class="form-label">
<i class="fa-solid fa-building icon"></i>
Company
</label>

<input
type="text"
class="form-control"
th:field="*{company}"
placeholder="Enter Company Name"
required>

</div>

<div class="col-md-6 mb-3">

<label class="form-label">
<i class="fa-solid fa-layer-group icon"></i>
Category
</label>

<input
type="text"
class="form-control"
th:field="*{category}"
placeholder="Tablet / Syrup / Injection"
required>

</div>

<div class="col-md-6 mb-3">

<label class="form-label">
<i class="fa-solid fa-indian-rupee-sign icon"></i>
Price
</label>

<input
type="number"
step="0.01"
class="form-control"
th:field="*{price}"
placeholder="Price"
required>

</div>

<div class="col-md-6 mb-3">

<label class="form-label">
<i class="fa-solid fa-boxes-stacked icon"></i>
Quantity
</label>

<input
type="number"
class="form-control"
th:field="*{quantity}"
placeholder="Available Quantity"
required>

</div>

<div class="col-md-6 mb-3">

<label class="form-label">
<i class="fa-solid fa-calendar icon"></i>
Manufacture Date
</label>

<input
type="date"
class="form-control"
th:field="*{manufactureDate}">

</div>

<div class="col-md-6 mb-3">

<label class="form-label">
<i class="fa-solid fa-calendar-xmark icon"></i>
Expiry Date
</label>

<input
type="date"
class="form-control"
th:field="*{expiryDate}">

</div>

<div class="col-md-12 mb-3">

<label class="form-label">
<i class="fa-solid fa-note-sticky icon"></i>
Description
</label>

<textarea
class="form-control"
th:field="*{description}"
placeholder="Write Medicine Description..."></textarea>

</div>

</div>

<div class="text-center mt-4">

<button type="submit" class="btn btn-success">

<i class="fa-solid fa-floppy-disk"></i>

Save Medicine

</button>

<a th:href="@{/medicine}" class="btn btn-secondary">

<i class="fa-solid fa-arrow-left"></i>

Back

</a>

</div>

</form>

</div>

</div>

</div>

</div>

</div>

</body>

</html>