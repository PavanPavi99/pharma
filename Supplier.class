<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

<meta charset="UTF-8">

<title>PharmaLens Reports</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">


<style>

body{
    background:#eef5ff;
    font-family:'Segoe UI',sans-serif;
}


.container-box{

    margin:40px;

}


.header{

    background:linear-gradient(45deg,#0d6efd,#00c6ff);
    color:white;
    padding:25px;
    border-radius:20px;
    margin-bottom:30px;
    box-shadow:0 5px 15px rgba(0,0,0,.2);

}



.card-box{

    color:white;
    padding:25px;
    border-radius:20px;
    box-shadow:0 8px 18px rgba(0,0,0,.2);
    transition:.3s;

}


.card-box:hover{

    transform:translateY(-8px);

}



.blue{

background:linear-gradient(45deg,#007bff,#00d4ff);

}


.green{

background:linear-gradient(45deg,#28a745,#7CFC00);

}


.orange{

background:linear-gradient(45deg,#ff9800,#ff5722);

}


.red{

background:linear-gradient(45deg,#dc3545,#ff6b81);

}


.purple{

background:linear-gradient(45deg,#6f42c1,#d63384);

}



.card-box i{

font-size:45px;
float:right;

}



.number{

font-size:40px;
font-weight:bold;

}



.table-box{

background:white;
padding:25px;
border-radius:20px;
margin-top:30px;
box-shadow:0 5px 15px rgba(0,0,0,.15);

}


</style>


</head>


<body>


<div class="container-box">



<div class="header">

<h1>
📊 PharmaLens Reports Dashboard
</h1>

<p>
Complete pharmacy statistics
</p>

</div>





<div class="row g-4">



<div class="col-md-3">

<div class="card-box blue">

<i class="fa-solid fa-capsules"></i>

<div class="number" th:text="${totalMedicines}">
0
</div>

<h5>
Total Medicines
</h5>

</div>

</div>





<div class="col-md-3">

<div class="card-box green">

<i class="fa-solid fa-users"></i>

<div class="number" th:text="${totalCustomers}">
0
</div>

<h5>
Total Customers
</h5>

</div>

</div>





<div class="col-md-3">

<div class="card-box orange">

<i class="fa-solid fa-truck"></i>

<div class="number" th:text="${totalSuppliers}">
0
</div>

<h5>
Total Suppliers
</h5>

</div>

</div>





<div class="col-md-3">

<div class="card-box red">

<i class="fa-solid fa-file-invoice"></i>

<div class="number" th:text="${totalBills}">
0
</div>

<h5>
Total Bills
</h5>

</div>

</div>



</div>






<br>




<div class="row">


<div class="col-md-6">


<div class="card-box purple">


<i class="fa-solid fa-indian-rupee-sign"></i>


<div class="number">

₹ <span th:text="${totalSales}">
0
</span>

</div>


<h5>
Total Sales
</h5>


</div>


</div>


</div>






<!-- Low Stock Report -->


<div class="table-box">


<h3>
⚠ Low Stock Medicines
</h3>



<table class="table table-bordered table-hover mt-3">


<thead class="table-danger">


<tr>

<th>Medicine Name</th>

<th>Company</th>

<th>Category</th>

<th>Quantity</th>

<th>Status</th>

</tr>


</thead>



<tbody>



<tr th:each="medicine : ${lowStock}">


<td th:text="${medicine.medicineName}">
</td>


<td th:text="${medicine.company}">
</td>


<td th:text="${medicine.category}">
</td>


<td th:text="${medicine.quantity}">
</td>



<td>

<span class="badge bg-danger">

Low Stock

</span>

</td>



</tr>



<tr th:if="${#lists.isEmpty(lowStock)}">


<td colspan="5" class="text-center">

No Low Stock Medicines

</td>


</tr>



</tbody>



</table>



</div>






<br>



<a href="/dashboard" class="btn btn-secondary">

⬅ Back Dashboard

</a>



</div>



</body>

</html>