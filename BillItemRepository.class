<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

<meta charset="UTF-8">

<title>Supplier Management</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

body{
    background:#eef5ff;
    font-family:Arial,sans-serif;
}

.container-box{

    margin-top:40px;
    background:white;
    padding:30px;
    border-radius:20px;
    box-shadow:0 5px 20px rgba(0,0,0,.15);

}

.header{

    background:linear-gradient(45deg,#0d6efd,#00c6ff);
    color:white;
    padding:20px;
    border-radius:15px;
    margin-bottom:25px;

}

.btn-add{

    background:#198754;
    color:white;
    border-radius:10px;

}

.table{

    border-radius:15px;
    overflow:hidden;

}

</style>

</head>


<body>


<div class="container">

<div class="container-box">


<div class="header">

<h2>
<i class="fa-solid fa-truck"></i>
Supplier Management
</h2>

</div>


<a href="/supplier/add" class="btn btn-add mb-3">

<i class="fa-solid fa-plus"></i>
Add Supplier

</a>


<table class="table table-hover table-bordered">


<thead class="table-primary">

<tr>

<th>ID</th>

<th>Supplier Name</th>

<th>Company</th>

<th>Email</th>

<th>Phone</th>

<th>City</th>

<th>Actions</th>

</tr>

</thead>


<tbody>


<tr th:each="supplier : ${suppliers}">


<td th:text="${supplier.id}"></td>


<td th:text="${supplier.supplierName}"></td>


<td th:text="${supplier.companyName}"></td>


<td th:text="${supplier.email}"></td>


<td th:text="${supplier.phone}"></td>


<td th:text="${supplier.city}"></td>



<td>


<a th:href="@{/supplier/view/{id}(id=${supplier.id})}"
class="btn btn-info btn-sm text-white">

<i class="fa-solid fa-eye"></i>

</a>



<a th:href="@{/supplier/edit/{id}(id=${supplier.id})}"
class="btn btn-warning btn-sm">

<i class="fa-solid fa-pen"></i>

</a>



<a th:href="@{/supplier/delete/{id}(id=${supplier.id})}"
class="btn btn-danger btn-sm"
onclick="return confirm('Delete this supplier?')">

<i class="fa-solid fa-trash"></i>

</a>


</td>


</tr>


</tbody>


</table>


<a href="/dashboard" class="btn btn-secondary">

<i class="fa-solid fa-arrow-left"></i>
Dashboard

</a>


</div>

</div>


</body>

</html>