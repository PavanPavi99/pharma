<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

<meta charset="UTF-8">

<title>Edit Medicine | PharmaLens</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

body{
background:#eef5ff;
font-family:Arial,sans-serif;
}

.card{
margin-top:40px;
border:none;
border-radius:20px;
box-shadow:0 10px 20px rgba(0,0,0,.2);
}

.card-header{
background:linear-gradient(45deg,#ff9800,#ff5722);
color:white;
padding:20px;
}

.form-control{
border-radius:10px;
}

.btn{
border-radius:10px;
}

</style>

</head>

<body>

<div class="container">

<div class="card">

<div class="card-header">

<h2>
<i class="fa-solid fa-pen"></i>
Edit Medicine
</h2>

</div>

<div class="card-body">

<form th:action="@{/medicine/update}"
      th:object="${medicine}"
      method="post">

<input type="hidden"
       th:field="*{id}">

<div class="row">

<div class="col-md-6 mb-3">

<label>Medicine Name</label>

<input
class="form-control"
type="text"
th:field="*{medicineName}">

</div>

<div class="col-md-6 mb-3">

<label>Company</label>

<input
class="form-control"
type="text"
th:field="*{company}">

</div>

<div class="col-md-6 mb-3">

<label>Category</label>

<input
class="form-control"
type="text"
th:field="*{category}">

</div>

<div class="col-md-6 mb-3">

<label>Price</label>

<input
class="form-control"
type="number"
step="0.01"
th:field="*{price}">

</div>

<div class="col-md-6 mb-3">

<label>Quantity</label>

<input
class="form-control"
type="number"
th:field="*{quantity}">

</div>

<div class="col-md-6 mb-3">

<label>Manufacture Date</label>

<input
class="form-control"
type="date"
th:field="*{manufactureDate}">

</div>

<div class="col-md-6 mb-3">

<label>Expiry Date</label>

<input
class="form-control"
type="date"
th:field="*{expiryDate}">

</div>

<div class="col-md-12 mb-3">

<label>Description</label>

<textarea
class="form-control"
th:field="*{description}">
</textarea>

</div>

</div>

<button class="btn btn-warning">

<i class="fa-solid fa-pen"></i>

Update Medicine

</button>

<a th:href="@{/medicine}" class="btn btn-secondary">

Back

</a>

</form>

</div>

</div>

</div>

</body>

</html>