<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>

<meta charset="UTF-8">
<title>PharmaLens Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{
background:#edf3ff;
}

/* Sidebar */

.sidebar{
position:fixed;
left:0;
top:0;
width:250px;
height:100%;
background:linear-gradient(180deg,#0d6efd,#003b95);
color:white;
overflow:auto;
}

.sidebar h2{
text-align:center;
padding:25px;
font-weight:bold;
}

.sidebar a{
display:block;
padding:15px 25px;
text-decoration:none;
color:white;
font-size:17px;
transition:.3s;
}

.sidebar a:hover{
background:white;
color:#0d6efd;
margin:5px;
border-radius:12px;
}

.sidebar i{
margin-right:10px;
}

/* Main */

.main{
margin-left:250px;
padding:25px;
}

/* Navbar */

.topbar{
background:white;
padding:15px 25px;
border-radius:15px;
box-shadow:0 5px 15px rgba(0,0,0,.1);
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:30px;
}

.search-box{
width:300px;
}

/* Cards */

.card-box{
border:none;
border-radius:20px;
color:white;
padding:25px;
transition:.3s;
box-shadow:0 8px 18px rgba(0,0,0,.2);
}

.card-box:hover{
transform:translateY(-8px);
}

.blue{
background:linear-gradient(45deg,#007bff,#00d4ff);
}

.green{
background:linear-gradient(45deg,#28a745,#7CFC00);
}

.orange{
background:linear-gradient(45deg,#ff9800,#ff5722);
}

.red{
background:linear-gradient(45deg,#dc3545,#ff6b81);
}

.card-box i{
font-size:45px;
float:right;
opacity:.8;
}

.table-box{
background:white;
margin-top:35px;
padding:25px;
border-radius:20px;
box-shadow:0 8px 18px rgba(0,0,0,.1);
}

.badge{
font-size:15px;
padding:8px 15px;
}

.profile{
font-size:18px;
font-weight:bold;
}

.avatar{
width:45px;
height:45px;
border-radius:50%;
background:#0d6efd;
color:white;
display:flex;
justify-content:center;
align-items:center;
font-size:20px;
}

</style>

</head>

<body>

<div class="sidebar">

<h2>💊 PharmaLens</h2>

<a th:href="@{/dashboard}">
<i class="fa-solid fa-house"></i> Dashboard
</a>

<a th:href="@{/medicine}">
<i class="fa-solid fa-capsules"></i> Medicines
</a>

<a th:href="@{/customer}">
    <i class="fa-solid fa-users"></i> Customers
</a>

<a th:href="@{/supplier}">
    <i class="fa-solid fa-truck"></i> Suppliers
</a>

<a th:href="@{/bill}">
<i class="fa-solid fa-file-invoice-dollar"></i> Billing
</a>

<a th:href="@{/reports}">
<i class="fa-solid fa-chart-line"></i> Reports
</a>

<a th:href="@{/login}">
<i class="fa-solid fa-right-from-bracket"></i> Logout
</a>

</div>

<div class="main">

<div class="topbar">

	<form th:action="@{/medicine/search}" method="get" class="d-flex">

	    <input type="text"
	           name="keyword"
	           class="form-control search-box"
	           placeholder="Search Medicines..."
	           required>

	    <button type="submit" class="btn btn-primary ms-2">
	        <i class="fa-solid fa-magnifying-glass"></i> Search
	    </button>

	</form>
<div class="d-flex align-items-center">

<div class="avatar">
A
</div>

<div class="ms-3 profile">
Admin
</div>

</div>

</div>

<div class="row g-4">

<div class="col-md-3">

<div class="card-box blue">

<i class="fa-solid fa-capsules"></i>

<h1 th:text="${totalMedicines}">
0
</h1>

<p>Total Medicines</p>

</div>

</div>

<div class="col-md-3">

<div class="card-box green">

<i class="fa-solid fa-users"></i>

<h1 th:text="${totalCustomers}">
0
</h1>

<p>Customers</p>

</div>

</div>

<div class="col-md-3">

<div class="card-box orange">

<i class="fa-solid fa-truck"></i>

<h1 th:text="${totalSuppliers}">
0
</h1>

<p>Suppliers</p>

</div>

</div>

<div class="col-md-3">

<div class="card-box red">

<i class="fa-solid fa-file-invoice-dollar"></i>

<h1 th:text="${totalBills}">
0
</h1>

<p>Bills</p>

</div>

</div>

</div>

<div class="table-box">

<h3 class="mb-4">
⚠ Low Stock Medicines
</h3>

<table class="table table-hover">

<thead class="table-primary">

<tr>

<th>Medicine</th>

<th>Available Stock</th>

<th>Status</th>

</tr>

</thead>

<tbody>

<tr th:each="medicine : ${lowStockMedicines}">

    <td th:text="${medicine.medicineName}"></td>

    <td th:text="${medicine.quantity}"></td>

    <td>

        <span th:if="${medicine.quantity <= 5}"
              class="badge bg-danger">
            Low Stock
        </span>

        <span th:if="${medicine.quantity > 5 && medicine.quantity <= 10}"
              class="badge bg-warning text-dark">
            Running Out
        </span>

    </td>

</tr>

<tr th:if="${#lists.isEmpty(lowStockMedicines)}">

    <td colspan="3" class="text-center">
        No Low Stock Medicines
    </td>

</tr>

</tbody>

</table>

</div>

</div>

</body>
</html>