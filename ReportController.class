<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

<meta charset="UTF-8">

<title>Invoice</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#eef5ff;
}

.invoice-box{
    margin-top:40px;
    background:white;
    padding:40px;
    border-radius:20px;
    box-shadow:0 5px 20px rgba(0,0,0,.2);
}

.header{
    background:linear-gradient(45deg,#0d6efd,#00c6ff);
    color:white;
    padding:25px;
    border-radius:15px;
    text-align:center;
}

.info{
    margin-top:30px;
    padding:20px;
    background:#f8f9fa;
    border-radius:15px;
}

.total{
    font-size:22px;
    font-weight:bold;
    color:#198754;
}

.btn{
    border-radius:10px;
}

@media print{
    .no-print{
        display:none;
    }
}

</style>

</head>

<body>

<div class="container">

<div class="invoice-box">

<div class="header">

<h1>💊 PharmaLens</h1>

<h3>Medicine Invoice</h3>

</div>

<div class="info">

<div class="row">

<div class="col-md-6">
<h5>Bill ID</h5>
<p th:text="${bill.id}"></p>
</div>

<div class="col-md-6">
<h5>Date</h5>
<p th:text="${bill.billDate}"></p>
</div>

<div class="col-md-6">
<h5>Payment Status</h5>
<p th:text="${bill.paymentStatus}"></p>
</div>

</div>

</div>

<h4 class="mt-4">Medicine Details</h4>

<table class="table table-bordered">

<thead class="table-primary">

<tr>

<th>Medicine</th>
<th>Quantity</th>
<th>Price</th>
<th>Total</th>

</tr>

</thead>

<tbody>

<tr>

<td th:text="${bill.medicineName}"></td>

<td th:text="${bill.quantity}"></td>

<td th:text="${bill.price}"></td>

<td th:text="${bill.totalAmount}"></td>

</tr>

</tbody>

</table>

<div class="text-end mt-4">

<h3 class="total">

Total Amount : ₹
<span th:text="${bill.totalAmount}"></span>

</h3>

</div>

<div class="mt-4 no-print">

<button onclick="window.print()" class="btn btn-primary">

🖨 Print Invoice

</button>

<a href="/bill" class="btn btn-secondary">

Back

</a>

</div>

</div>

</div>

</body>

</html>