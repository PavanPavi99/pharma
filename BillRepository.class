<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

<meta charset="UTF-8">

<title>View Supplier</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


<style>

body{
    background:#eef5ff;
}

.card{

    margin-top:60px;
    border-radius:20px;
    box-shadow:0 5px 20px rgba(0,0,0,.2);

}

.card-header{

    background:linear-gradient(45deg,#198754,#20c997);
    color:white;
    border-radius:20px 20px 0 0;

}


.detail-box{

    background:#f8f9fa;
    padding:15px;
    border-radius:10px;
    margin-bottom:15px;

}


label{

    font-weight:bold;
    color:#0d6efd;

}


.btn{

    border-radius:10px;

}


</style>

</head>


<body>


<div class="container">


<div class="card">


<div class="card-header">

<h3>
🚚 Supplier Details
</h3>

</div>



<div class="card-body">


<div class="row">


<div class="col-md-6">


<div class="detail-box">

<label>Supplier Name</label>

<p th:text="${supplier.supplierName}"></p>

</div>


</div>



<div class="col-md-6">


<div class="detail-box">

<label>Company Name</label>

<p th:text="${supplier.companyName}"></p>

</div>


</div>



<div class="col-md-6">


<div class="detail-box">

<label>Email</label>

<p th:text="${supplier.email}"></p>

</div>


</div>



<div class="col-md-6">


<div class="detail-box">

<label>Phone</label>

<p th:text="${supplier.phone}"></p>

</div>


</div>



<div class="col-md-12">


<div class="detail-box">

<label>Address</label>

<p th:text="${supplier.address}"></p>

</div>


</div>



<div class="col-md-4">


<div class="detail-box">

<label>City</label>

<p th:text="${supplier.city}"></p>

</div>


</div>



<div class="col-md-4">


<div class="detail-box">

<label>State</label>

<p th:text="${supplier.state}"></p>

</div>


</div>



<div class="col-md-4">


<div class="detail-box">

<label>Pincode</label>

<p th:text="${supplier.pincode}"></p>

</div>


</div>



</div>



<a href="/supplier" class="btn btn-primary">

⬅ Back to Suppliers

</a>


<a th:href="@{/supplier/edit/{id}(id=${supplier.id})}"
class="btn btn-warning">

✏ Edit

</a>



</div>


</div>


</div>


</body>

</html>