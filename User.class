<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

<meta charset="UTF-8">

<title>Add Supplier</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


<style>

body{
    background:#eef5ff;
}

.card{

    margin-top:50px;
    border-radius:20px;
    box-shadow:0 5px 20px rgba(0,0,0,.2);

}

.card-header{

    background:linear-gradient(45deg,#0d6efd,#00c6ff);
    color:white;
    border-radius:20px 20px 0 0;

}

.form-control{

    border-radius:10px;

}

.btn{

    border-radius:10px;

}

</style>


</head>


<body>


<div class="container">


<div class="card">


<div class="card-header">

<h3>
🚚 Add Supplier
</h3>

</div>


<div class="card-body">


<form th:action="@{/supplier/save}"
      th:object="${supplier}"
      method="post">


<div class="row">


<div class="col-md-6 mb-3">

<label>Supplier Name</label>

<input type="text"
class="form-control"
th:field="*{supplierName}"
required>

</div>



<div class="col-md-6 mb-3">

<label>Company Name</label>

<input type="text"
class="form-control"
th:field="*{companyName}"
required>

</div>



<div class="col-md-6 mb-3">

<label>Email</label>

<input type="email"
class="form-control"
th:field="*{email}">

</div>



<div class="col-md-6 mb-3">

<label>Phone</label>

<input type="text"
class="form-control"
th:field="*{phone}"
required>

</div>



<div class="col-md-12 mb-3">

<label>Address</label>

<textarea class="form-control"
th:field="*{address}">
</textarea>

</div>



<div class="col-md-4 mb-3">

<label>City</label>

<input type="text"
class="form-control"
th:field="*{city}">

</div>



<div class="col-md-4 mb-3">

<label>State</label>

<input type="text"
class="form-control"
th:field="*{state}">

</div>



<div class="col-md-4 mb-3">

<label>Pincode</label>

<input type="text"
class="form-control"
th:field="*{pincode}">

</div>


</div>



<button type="submit"
class="btn btn-success">

<i class="fa-solid fa-save"></i>
Save Supplier

</button>


<a href="/supplier"
class="btn btn-secondary">

Back

</a>


</form>


</div>


</div>


</div>


</body>

</html>